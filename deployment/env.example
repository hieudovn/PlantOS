# ============================================
# PlantOS Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values:
#   cp env.example .env
# Never commit the .env file to version control.

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=plantos
POSTGRES_USER=plantos
POSTGRES_PASSWORD=change-me           # Required — no default

# TDengine (Time-Series Database)
TDENGINE_HOST=tdengine
TDENGINE_REST_PORT=6041
TDENGINE_NATIVE_PORT=6030
TDENGINE_DATABASE=plantos_ts
TDENGINE_USER=root
TDENGINE_PASSWORD=change-me           # Required — no default

# JWT Secret (for token signing)
JWT_SECRET=change-me                   # Required — generate via: python -c "import secrets; print(secrets.token_urlsafe(24))"

# API Keys (for internal service-to-service auth)
EDGE_API_KEY=plantos-edge-change-me    # Required — used by Edge Agent
FRONTEND_DEMO_KEY=plantos-frontend-change-me  # Required — used by demo tools

# EMQX (MQTT Broker)
EMQX_HOST=emqx
EMQX_MQTT_PORT=1883
EMQX_WS_PORT=8083
EMQX_DASHBOARD_PORT=18083
MQTT_USER=edge-agent
MQTT_PASSWORD=change-me                # Required — for MQTT auth

# PlantOS Backend
BACKEND_PORT=8000
DEBUG=false
ENVIRONMENT=production

# PlantOS Frontend
FRONTEND_PORT=5173
