# PostgreSQL — no defaults in production; set all values explicitly
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=<REQUIRED>
POSTGRES_USER=<REQUIRED>
POSTGRES_PASSWORD=<REQUIRED>

# TDengine (Time-Series Database)
TDENGINE_HOST=tdengine
TDENGINE_REST_PORT=6041
TDENGINE_NATIVE_PORT=6030
TDENGINE_DATABASE=plantos_ts

# Authentication — generate with: openssl rand -hex 32
JWT_SECRET=<REQUIRED>
API_KEYS=<REQUIRED>

# EMQX (MQTT Broker)
EMQX_HOST=emqx
EMQX_MQTT_PORT=1883
EMQX_WS_PORT=8083
EMQX_DASHBOARD_PORT=18083

# PlantOS Backend
BACKEND_PORT=8000

# PlantOS Frontend
FRONTEND_PORT=5173
